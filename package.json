{
  "name": "obsidian-table-formatter",
  "version": "1.3.4",
  "description": "An Obsidian plugin that formats Markdown tables on save.",
  "main": "main.js",
  "scripts": {
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "dev": "node esbuild.config.mjs",
    "lint": "eslint main.ts --max-warnings=0",
    "lint:fix": "eslint main.ts --fix --max-warnings=0",
    "test": "node --import tsx --test tests/tableFormatter.test.ts",
    "version:patch": "node scripts/bump-patch-version.mjs",
    "version:minor": "node scripts/bump-minor-version.mjs",
    "version:major": "node scripts/bump-major-version.mjs"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "markdown",
    "table"
  ],
  "author": "fangface",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.16.5",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "esbuild": "^0.23.1",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "obsidian": "latest",
    "tslib": "^2.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
